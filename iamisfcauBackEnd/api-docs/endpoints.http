@baseUrl = http://localhost:8080
# @token = paste_your_token_here

### ===================== ActivityController =====================

### GET /api/activities (list)
GET {{baseUrl}}/api/activities

### GET /api/activities/joined (joined)
GET {{baseUrl}}/api/activities/joined

### GET /api/activities/{id} (detail)
GET {{baseUrl}}/api/activities/{id}

### GET /api/activities/{id}/attendance (attendance)
GET {{baseUrl}}/api/activities/{id}/attendance

### PUT /api/activities/{id}/attendance/{userId} (updateAttendance)
PUT {{baseUrl}}/api/activities/{id}/attendance/{userId}
Content-Type: application/json

{
  "attendStatus": "string",
  "isLate": true
}

### DELETE /api/activities/{id}/join (cancelJoin)
DELETE {{baseUrl}}/api/activities/{id}/join

### POST /api/activities/{id}/join (join)
POST {{baseUrl}}/api/activities/{id}/join
Content-Type: application/json

{
  "userId": "string"
}


### ===================== ActivityCreateApprovalController =====================

### GET /api/activity-create-approvals (list)
GET {{baseUrl}}/api/activity-create-approvals

### POST /api/activity-create-approvals (create)
POST {{baseUrl}}/api/activity-create-approvals
Content-Type: application/json

{
  "title": "string",
  "organizer": "string",
  "leaderId": "string",
  "startAt": "string",
  "endAt": "string",
  "location": "string",
  "summary": "string",
  "content": "string"
}

### DELETE /api/activity-create-approvals/{applyId} (withdraw)
DELETE {{baseUrl}}/api/activity-create-approvals/{applyId}

### POST /api/activity-create-approvals/{applyId}/approve (approve)
POST {{baseUrl}}/api/activity-create-approvals/{applyId}/approve
Content-Type: application/json

{
  "approvalComment": "string"
}

### POST /api/activity-create-approvals/{applyId}/reject (reject)
POST {{baseUrl}}/api/activity-create-approvals/{applyId}/reject
Content-Type: application/json

{
  "approvalComment": "string"
}


